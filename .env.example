# Optional — enables the "Send email" button on Add Client. Without these,
# the app still works fully via copy-link / copy-SMS. Get a key from
# resend.com; RESEND_FROM_EMAIL must be on a domain verified in that account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional — recipient inbox for the public "Book a Consultation" lead form
# on the marketing homepage. Requires RESEND_API_KEY above to also be set;
# without both, the form falls back to a mailto: link automatically.
LEAD_NOTIFICATION_EMAIL=

# Public contact email shown in the marketing homepage footer and used as
# the mailto: fallback for the consultation form. Safe to expose client-side.
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
